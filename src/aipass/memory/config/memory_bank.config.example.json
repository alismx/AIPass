{
  "memory_pool": {
    "enabled": false,
    "process_on_startup": false,
    "extensions": [".md", ".txt"]
  },
  "rollover": {
    "defaults": {
      "max_lines": 500,
      "archive_oldest": 100
    },
    "per_branch": {}
  },
  "intake": {
    "enabled": false,
    "pool_dir": "memory_pool"
  }
}
