# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/

# Environment
.env

# Tools
.ruff_cache/

# Docs
site/

# IDE
.idea/
.vscode/
*.swp

# AIPass global config — ignore secrets, track prompts
.aipass/platform_keys.env

.archive

# Dev-Pass spawn artifacts (generated post-install, not source code)
.trinity/
.agent/
DASHBOARD.local.json
flow.local.md
artifacts/
tools/
aipass_json/

# JSON — runtime data, constantly changing
*.json

# JSON exceptions — source templates and configs that ship with the package
!**/json_templates/**
!**/pack.json
!.claude/settings.json
!pyrightconfig.json

# Spawn templates MUST be tracked (agents need these files to build from)
!src/aipass/spawn/templates/**/.trinity/
!src/aipass/spawn/templates/**/.trinity/**
!src/aipass/spawn/templates/**/.agent/
!src/aipass/spawn/templates/**/.agent/**
!src/aipass/spawn/templates/**/.aipass/
!src/aipass/spawn/templates/**/.aipass/**
!src/aipass/spawn/templates/**/.archive
!src/aipass/spawn/templates/**/.archive/**
!src/aipass/spawn/templates/**/artifacts/
!src/aipass/spawn/templates/**/artifacts/**
!src/aipass/spawn/templates/**/tools/
!src/aipass/spawn/templates/**/tools/**
!src/aipass/spawn/templates/**/DASHBOARD.local.json
!src/aipass/spawn/templates/**/flow.local.md
!src/aipass/spawn/templates/**/.seed/
!src/aipass/spawn/templates/**/.seed/**
!src/aipass/spawn/templates/**/.standards/
!src/aipass/spawn/templates/**/.standards/**
!src/aipass/spawn/templates/**/.backup/
!src/aipass/spawn/templates/**/.backup/**
!src/aipass/spawn/templates/**/.ai_mail.local/
!src/aipass/spawn/templates/**/.ai_mail.local/**
!src/aipass/spawn/templates/**/.claude/
!src/aipass/spawn/templates/**/.claude/**
!src/aipass/spawn/templates/**/*.json

# Seedgo runtime artifacts (created by seedgo audit)
.seed/
.standards/

# Runtime log files (created by prax logging)
**/logs

# Claude — ignore runtime dirs, track config + hooks + sounds
.claude/file-history/
.claude/debug/
.claude/downloads/
.claude/ide/
.claude/paste-cache/
.claude/projects/
.claude/session-env/
.claude/shell-snapshots/
.claude/statsig/
.claude/tasks/
.claude/todos/
.claude/user_data/
.claude/.credentials.json
.claude/history.jsonl
.claude/hooks/__pycache__/
.claude/hooks/.last_diagnostics_file
.claude/hooks/.pre_compact_log

# setup-workspace.sh — tracked, needed for Docker build
src/aipass/trigger/trigger_json/trigger_data.json


