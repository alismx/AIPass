{
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git config:*)",
      "Bash(git push --force:*)",
      "EnterPlanMode"
    ],
    "defaultMode": "acceptEdits"
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/patrick/.claude/hooks/auto_fix_diagnostics.py"
          }
        ]
      }
    ]
  }
}
